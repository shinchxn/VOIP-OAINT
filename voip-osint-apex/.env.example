# ── VoIP OSINT APEX v3.0 — Environment Variables ─────────────────────────────
# Copy to .env and fill in your real keys.
# Keys marked REQUIRED are needed for core functionality.

# ── Required API Keys ─────────────────────────────────────────────────────────
IPQS_KEY=your_ipqualityscore_key_here
SHODAN_KEY=your_shodan_key_here
ABUSEIPDB_KEY=your_abuseipdb_key_here
VIRUSTOTAL_KEY=your_virustotal_key_here
NUMVERIFY_KEY=your_numverify_key_here

# ── Optional API Keys ─────────────────────────────────────────────────────────
SECURITYTRAILS_KEY=your_securitytrails_key_here
HIBP_KEY=your_haveibeenpwned_key_here

# ── Application Settings ──────────────────────────────────────────────────────
VOIP_OUTPUT_DIR=outputs
VOIP_DEBUG=0

# ── Redis (leave default unless using remote Redis) ───────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
